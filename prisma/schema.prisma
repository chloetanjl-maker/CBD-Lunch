// Prisma schema for CBD Salad tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deal {
  id          Int      @id @default(autoincrement())
  name        String
  restaurant  String
  address     String
  price       Float
  description String?
  dealDays    String? // e.g. "Mon-Fri, 11:30am-2pm"
  link        String?
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
