// Prisma schema for CBD Caifan & Salad tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma enums work on Postgres, but `category` stays a plain string
// validated against CATEGORIES in src/lib/categories.ts to avoid a
// migration every time a category is added.
model Deal {
  id          Int      @id @default(autoincrement())
  name        String
  restaurant  String
  address     String
  category    String // "caifan" | "salad"
  price       Float
  description String?
  dealDays    String? // e.g. "Mon-Fri, 11:30am-2pm"
  link        String?
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}
