# Postgres connection string. When deploying on Vercel, create a database
# from the project's Storage tab (Neon/Vercel Postgres) and it will inject
# this automatically. For local dev, copy the same connection string here.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Required for the map view. Create a key in Google Cloud Console with the
# "Maps JavaScript API" enabled: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
